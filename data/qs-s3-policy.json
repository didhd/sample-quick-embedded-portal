{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Action": "s3:ListAllMyBuckets",
            "Resource": "arn:aws:s3:::*"
        },
        {
            "Effect": "Allow",
            "Action": ["s3:ListBucket"],
            "Resource": [
                "arn:aws:s3:::YOUR_DATA_BUCKET",
                "arn:aws:s3:::aws-athena-query-results-us-west-2-YOUR_ACCOUNT_ID"
            ]
        },
        {
            "Effect": "Allow",
            "Action": ["s3:GetObject", "s3:GetObjectVersion"],
            "Resource": [
                "arn:aws:s3:::YOUR_DATA_BUCKET/*",
                "arn:aws:s3:::aws-athena-query-results-us-west-2-YOUR_ACCOUNT_ID/*"
            ]
        },
        {
            "Effect": "Allow",
            "Action": ["s3:ListBucketMultipartUploads", "s3:GetBucketLocation"],
            "Resource": [
                "arn:aws:s3:::YOUR_DATA_BUCKET",
                "arn:aws:s3:::aws-athena-query-results-us-west-2-YOUR_ACCOUNT_ID"
            ]
        },
        {
            "Effect": "Allow",
            "Action": ["s3:PutObject", "s3:AbortMultipartUpload", "s3:ListMultipartUploadParts"],
            "Resource": ["arn:aws:s3:::aws-athena-query-results-us-west-2-YOUR_ACCOUNT_ID/*"]
        }
    ]
}
