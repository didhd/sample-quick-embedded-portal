# Copy to .env and fill in. .env is gitignored.
# Source before running deploy / data / cleanup scripts:
#   set -a && source .env && set +a

# AWS account + region this stack is deployed to.
AWS_ACCOUNT_ID=
AWS_REGION=us-west-2

# Quick Suite admin (federated IAM user that owns datasets/dashboards/agent).
# Format: <iam-role-or-group>/<iam-user-or-session-name>
# Find via: aws quicksight list-users --aws-account-id $AWS_ACCOUNT_ID --namespace default
QS_ADMIN_USER_NAME=Admin/your-iam-username

# S3 bucket holding the synthetic CSVs + manifests.
DEMO_DATA_BUCKET=

# CDK stack identifiers.
CDK_STACK_NAME=clearone
CDK_DEFAULT_ACCOUNT=
CDK_DEFAULT_REGION=us-west-2

# Quick Suite resource IDs (filled in after data/create_dashboard.py + console agent share).
DASHBOARD_ID=clearone-operations-dashboard
CHAT_AGENT_ID=

# Live deployment artefacts (filled in after `cdk deploy`).
CLOUDFRONT_DISTRIBUTION_ID=
CLOUDFRONT_URL=
FRONTEND_BUCKET=
API_GATEWAY_URL=
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
